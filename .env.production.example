APP_PORT=3103
APP_URL=https://bolao.minimalab.ai
AUTH_SECRET=generate-a-long-random-secret
ENABLE_DEMO_SEED=false

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_PASSWORD=generate-a-temporary-admin-password
INITIAL_ACCESS_TOKEN=choose-a-shared-invite-token

POSTGRES_DB=bolaov2
POSTGRES_USER=bolaov2
POSTGRES_PASSWORD=generate-a-strong-postgres-password

FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION_ID=2178
INTERNAL_CRON_SECRET=generate-a-long-random-cron-secret

# The production Docker Compose file injects DATABASE_URL internally.
# Keep DATABASE_SSL=false because the app talks to Postgres over Docker network.
DATABASE_SSL=false
